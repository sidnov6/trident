# ── TRIDENT environment ──────────────────────────────────────────────────
# Copy to .env and fill in. The system RUNS WITHOUT an AIS key in synthetic mode.

# AIS feed ------------------------------------------------------------------
# Get a free key at https://aisstream.io/  (key goes in the subscription msg).
AISSTREAM_API_KEY=
# "synthetic" replays a generated Suez scenario (no key needed); "live" uses AISStream.
AIS_SOURCE=synthetic

# Datastores (defaults match docker-compose; override for local-host runs) ---
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://trident:trident@localhost:5432/trident

# Cognition — Groq ----------------------------------------------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Desk agent web-search (optional). Needs a Tavily key if enabled.
DESK_SEARCH_ENABLED=false
TAVILY_API_KEY=

# Fusion layer (structured now, wired later) --------------------------------
FUSION_ENABLED=false
COPERNICUS_USER=
COPERNICUS_PASSWORD=
FRED_API_KEY=
EIA_API_KEY=

# Tuning --------------------------------------------------------------------
ESCALATION_TAU=0.6
LOG_LEVEL=INFO
